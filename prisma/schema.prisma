generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER

  @@map("role")
}


model Users {
id  Int  @id @default(autoincrement()) @map("id")
username String? @unique @map("username")
password  String? @map("password")
email String? @unique @map("email")
isBanned  Boolean  @default(false) @map("is_banned")
isDeleted  Boolean  @default(false) @map("is_deleted")
banEndAt DateTime? @map("ban_end_at")
role  Role  @default(USER) @map("role")
lastLoginIP  String?  @map("last_login_ip")
lastLoginAt  DateTime?  @default(now()) @map("last_login_at")
createdAt  DateTime?  @default(now()) @map("created_at")
updatedAt  DateTime?  @updatedAt @map("updated_at")
deletedAt  DateTime? @map("deleted_at")

profile Profiles?
address Addresses?

@@index(username)
@@index(email)
@@index(createdAt)
@@index(lastLoginIP)

@@map("user")
}

model Profiles {
userId  Int @id @map("user_id")
rating  Int  @map("rating")
balance  Decimal   @default(0) @map("balance") @db.Decimal(18, 6)
avatar  String?  @map("avatar")
level  Int  @default(0) @map("level")
createdAt  DateTime @default(now()) @map("created_at")
updatedAt  DateTime @updatedAt @map("updated_at")

address Addresses?

user Users @relation(fields: [userId], references: [id])

@@index(level)
@@index(rating)

@@map("profile")
}

model Addresses {
userId  Int  @id @map("user_id")
firstName  String   @map("first_name")
lastName   String  @map("last_name")
phoneNumber String  @map("phone_number")
address  String   @map("address")
address2  String?  @map("address2")
country  String?  @map("country")
postalCode  String  @map("postal_code")
city  String  @map("city")
createdAt  DateTime @default(now()) @map("created_at")
updatedAt  DateTime @updatedAt @map("updated_at")
user Users @relation(fields: [userId], references: [id], map: "address_user_id_fkey")
profile Profiles @relation(fields: [userId], references: [userId], map: "address_profile_user_id_fkey")

@@index(country)
@@index(city)

@@map("address")
}

model GameSession {
id String @id @default(uuid())
userId Int
serverSeed String
serverHash String
clientSeed String
nonce Int @default(0)
createdAt DateTime @default(now())
bets RouletteBet[]
}

model RouletteBet  {
id String @id @default(uuid())
gameId String
betType String
betAmount Int 
winningNumber Int
payoutAmount Int 
isWin Boolean
nonce Int
createdAt DateTime @default(now())
gameSession GameSession @relation(fields: [gameId], references: [id])
}

