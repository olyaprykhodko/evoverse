generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER

  @@map("role")
}

model Users {
  id          Int       @id @default(autoincrement()) @map("id")
  username    String?   @unique @map("username")
  password    String?   @map("password")
  email       String?   @unique @map("email")
  isBanned    Boolean   @default(false) @map("is_banned")
  isDeleted   Boolean   @default(false) @map("is_deleted")
  banEndAt    DateTime? @map("ban_end_at")
  role        Role      @default(USER) @map("role")
  lastLoginIP String?   @map("last_login_ip")
  lastLoginAt DateTime? @default(now()) @map("last_login_at")
  createdAt   DateTime? @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  profile      Profiles?
  address      Addresses?
  gameSessions GameSession[]
  rouletteBets RouletteBet[]
  wallet       Wallet?
  userWeapons  UserWeapon[]
  battlesAsP1  BattleSession[] @relation("player1_battles")
  battlesAsP2  BattleSession[] @relation("player2_battles")
  battleStats  BattleStats?
  slotSpins    SlotSpin[]

  @@index([username])
  @@index([email])
  @@index([createdAt])
  @@index([lastLoginIP])
  @@map("user")
}

model Profiles {
  userId    Int      @id @map("user_id")
  rating    Int      @default(0) @map("rating")
  avatar    String?  @map("avatar")
  level     Int      @default(0) @map("level")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  address Addresses?

  user Users @relation(fields: [userId], references: [id])

  @@index([level])
  @@index([rating])
  @@map("profile")
}

model Addresses {
  userId      Int      @id @map("user_id")
  firstName   String   @map("first_name")
  lastName    String   @map("last_name")
  phoneNumber String   @map("phone_number")
  address     String   @map("address")
  address2    String?  @map("address2")
  country     String?  @map("country")
  postalCode  String   @map("postal_code")
  city        String   @map("city")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  user        Users    @relation(fields: [userId], references: [id], map: "address_user_id_fkey")
  profile     Profiles @relation(fields: [userId], references: [userId], map: "address_profile_user_id_fkey")

  @@index([country])
  @@index([city])
  @@map("address")
}

model GameSession {
  id         String   @id @default(uuid())
  userId     Int      @map("user_id")
  serverSeed String   @map("server_seed")
  serverHash String   @map("server_hash")
  clientSeed String?  @map("client_seed")
  nonce      Int      @default(0)
  isOpen     Boolean  @default(true) @map("is_open")
  createdAt  DateTime @default(now()) @map("created_at")

  user Users         @relation(fields: [userId], references: [id])
  bets RouletteBet[]

  @@index([userId])
  @@index([isOpen])
  @@map("game_session")
}

model RouletteBet {
  id            String   @id @default(uuid())
  userId        Int      @map("user_id")
  gameId        String   @map("game_id")
  betType       String   @map("bet_type")
  targetNumber  Int?     @map("target_number")
  betAmount     Int      @map("bet_amount")
  winningNumber Int      @map("winning_number")
  payoutAmount  Int      @map("payout_amount")
  isWin         Boolean  @map("is_win")
  nonce         Int
  createdAt     DateTime @default(now()) @map("created_at")

  user        Users       @relation(fields: [userId], references: [id])
  gameSession GameSession @relation(fields: [gameId], references: [id])

  @@index([userId])
  @@index([gameId])
  @@index([isWin])
  @@map("roulette_bet")
}

enum TransactionType {
  DEPOSIT   
  WITHDRAWAL 
  PAYOUT    

  @@map("transaction_type")
}

model Wallet {
  id        String   @id @default(uuid())
  userId    Int      @unique @map("user_id")
  balance   Decimal  @default(0) @db.Decimal(18, 6) @map("balance")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user         Users               @relation(fields: [userId], references: [id])
  transactions WalletTransaction[]
  coins        Int                 @default(0) @map("coins")
  coinTransactions CoinTransaction[]

  @@map("wallet")
}

model WalletTransaction {
  id             String          @id @default(uuid())
  walletId       String          @map("wallet_id")
  type           TransactionType @map("type")
  amount         Decimal         @db.Decimal(18, 6) @map("amount")
  balanceBefore  Decimal         @db.Decimal(18, 6) @map("balance_before")
  balanceAfter   Decimal         @db.Decimal(18, 6) @map("balance_after")
  idempotencyKey String          @unique @map("idempotency_key")
  description    String?         @map("description")
  referenceId    String?         @map("reference_id")
  createdAt      DateTime        @default(now()) @map("created_at")

  wallet Wallet @relation(fields: [walletId], references: [id])

  @@index([walletId])
  @@index([referenceId])
  @@map("wallet_transaction")
}

enum CoinTransactionType {
  EARNED_BATTLE
  SPENT_WEAPON
  CONVERTED_TO_CASH
  ROULETTE_BET
  ROULETTE_WIN
  PURCHASED_COINS
  SLOT_BET
  SLOT_WIN

  @@map("coin_transaction_type")
}

model CoinTransaction {
  id            String              @id @default(uuid())
  walletId      String              @map("wallet_id")
  type          CoinTransactionType @map("type")
  amount        Int                 @map("amount")
  balanceBefore Int                 @map("balance_before")
  balanceAfter  Int                 @map("balance_after")
  referenceId   String?             @map("reference_id")
  description   String?             @map("description")
  createdAt     DateTime            @default(now()) @map("created_at")

  wallet Wallet @relation(fields: [walletId], references: [id])

  @@index([walletId])
  @@map("coin_transaction")
}

enum WeaponRarity {
  COMMON
  RARE
  EPIC
  LEGENDARY

  @@map("weapon_rarity")
}

model Weapon {
  id        Int          @id @default(autoincrement())
  name      String       @unique @map("name")
  price     Int          @map("price")
  minDamage Int          @map("min_damage")
  maxDamage Int          @map("max_damage")
  rarity    WeaponRarity @map("rarity")
  createdAt DateTime     @default(now()) @map("created_at")

  userWeapons  UserWeapon[]
  battlesAsW1  BattleSession[] @relation("weapon1_battles")
  battlesAsW2  BattleSession[] @relation("weapon2_battles")

  @@map("weapon")
}

model UserWeapon {
  id       String   @id @default(uuid())
  userId   Int      @map("user_id")
  weaponId Int      @map("weapon_id")
  boughtAt DateTime @default(now()) @map("bought_at")

  user   Users  @relation(fields: [userId], references: [id])
  weapon Weapon @relation(fields: [weaponId], references: [id])

  @@unique([userId, weaponId])
  @@index([userId])
  @@map("user_weapon")
}


enum BattleStatus {
  WAITING
  IN_PROGRESS
  FINISHED
  ABANDONED

  @@map("battle_status")
}

model BattleSession {
  id         String       @id @default(uuid())
  player1Id  Int          @map("player1_id")
  player2Id  Int          @map("player2_id")
  weapon1Id  Int          @map("weapon1_id")
  weapon2Id  Int          @map("weapon2_id")
  status     BattleStatus @default(IN_PROGRESS) @map("status")
  winnerId   Int?         @map("winner_id")
  rounds     Json         @default("[]") @map("rounds")
  createdAt  DateTime     @default(now()) @map("created_at")
  finishedAt DateTime?    @map("finished_at")

  player1 Users  @relation("player1_battles", fields: [player1Id], references: [id])
  player2 Users  @relation("player2_battles", fields: [player2Id], references: [id])
  weapon1 Weapon @relation("weapon1_battles", fields: [weapon1Id], references: [id])
  weapon2 Weapon @relation("weapon2_battles", fields: [weapon2Id], references: [id])

  @@index([player1Id])
  @@index([player2Id])
  @@index([status])
  @@map("battle_session")
}

model SlotSpin {
  id           String   @id @default(uuid())
  userId       Int      @map("user_id")
  serverSeed   String   @map("server_seed")
  serverHash   String   @map("server_hash")
  clientSeed   String   @map("client_seed")
  nonce        Int
  stop1        Int      @map("stop1")
  stop2        Int      @map("stop2")
  stop3        Int      @map("stop3")
  sym1         String   @map("sym1")
  sym2         String   @map("sym2")
  sym3         String   @map("sym3")
  betAmount    Int      @map("bet_amount")
  payoutAmount Int      @map("payout_amount")
  isWin        Boolean  @map("is_win")
  winType      String?  @map("win_type")
  createdAt    DateTime @default(now()) @map("created_at")

  user Users @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isWin])
  @@map("slot_spin")
}

model BattleStats {
  userId        Int @id @map("user_id")
  totalWins     Int @default(0) @map("total_wins")
  totalLosses   Int @default(0) @map("total_losses")
  currentStreak Int @default(0) @map("current_streak")
  maxStreak     Int @default(0) @map("max_streak")

  user Users @relation(fields: [userId], references: [id])

  @@map("battle_stats")
}
